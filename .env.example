# Copy to .env.local for local dev (never commit .env.local)

# Gemini — same variable in Vercel → Project → Settings → Environment Variables (all envs)
GEMINI_API_KEY=

# Only if generateEphemeralToken returns 404 AND you accept sending the API key to the browser.
# Ignored on local `next dev` (fallback allowed). On Vercel production/preview, required to enable fallback.
# ALLOW_CLIENT_API_KEY_FALLBACK=true
