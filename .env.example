# Copy to .env.local for local dev (never commit .env.local)

# Gemini — same variable in Vercel → Project → Settings → Environment Variables (Production + Preview)
GEMINI_API_KEY=

# Session tokens are created with v1alpha authTokens (see app/api/token/route.ts).
# If that fails locally, the route may fall back to sending the API key to the browser.

# Emergency only on Vercel if authTokens.create fails and you accept exposing the key to clients:
# ALLOW_CLIENT_API_KEY_FALLBACK=true
